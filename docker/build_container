#!/usr/bin/bash
xhost +local:docker 

XSOCK=/tmp/.X11-unix
XAUTH=/tmp/.docker.xauth
touch $XAUTH
if [ ! -f $XAUTH ]
then
    xauth_list=$(xauth nlist :0 | sed -e 's/^..../ffff/')
    if [ ! -z "$xauth_list" ]
    then
        echo $xauth_list | xauth -f $XAUTH nmerge -
    else
        touch $XAUTH
    fi
    chmod a+r $XAUTH
fi

data_path=/mnt/bigbertha_mount/data
container_name=contourpose-baseline-4090
img_name=$container_name


docker stop $container_name & docker container rm $container_name 

docker run -it \
	--name $container_name \
	--volume=$XSOCK:$XSOCK:rw \
        --volume=$XAUTH:$XAUTH:rw \
	--volume=$data_path:/data \
	--volume=/mnt/bigbertha_mount/data/Datasets/ContourPose/SUN2012pascalformat:/data/Datasets/ContourPose/SUN2012pascalformat \
	-p=9000:9000/tcp \
	-p=7000:7000/tcp \
        --volume=/dev:/dev \
        --privileged \
        --volume=$PWD:/$container_name \
        -w /$container_name \
	--env="XAUTHORITY=$XAUTH" \
	--env="DISPLAY=$DISPLAY" \
	--env="QT_X11_NO_MITSHM=1" \
	--runtime=nvidia \
	--net=host --gpus all \
	--env="NVIDIA_DRIVER_CAPABILITIES=all" \
	$img_name \
	bash
